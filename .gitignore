**/web/**/*.js.map

# Windows
**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h

# Linux
**/linux/flutter/generated_plugin_registrant.cc
**/linux/flutter/generated_plugin_registrant.h

# Exceptions to above rules - keep example structure files
!**/ios/**/Podfile
!**/ios/**/Runner/
!**/android/**/app/
!**/android/**/gradle/

# Environment & Config files (Security)
.env
.env.*
*.env
.env.local
.env.production
.env.development
*.config.local
config.local.*
secrets.yaml
secrets.json

# API Keys and Credentials (Security)
**/api_keys.dart
**/secrets.dart
**/credentials.json
**/credentials.dart
**/*_secret.dart
**/*_key.dart
**/*.pem
**/*.key
**/*.p12
**/*.mobileprovision
**/GoogleService-Info.plist
**/google-services.json
firebase_options.dart

# Build outputs
*.apk
*.aab
*.ipa
*.app
*.dSYM.zip
*.dSYM

# Lock files (keep for packages, ignore for examples)
pubspec.lock
